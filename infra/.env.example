# Backend
BACKEND_PORT=8001
MONGODB_URL=mongodb://mongo:27017
DATABASE_NAME=openinfra
REDIS_URL=redis://redis:6379/0
CSV_IMPORT_URL=https://contribapi.openinfra.space/api/export_csv?types=tram_dien,cot_dien,duong_ong_dien,den_duong,den_giao_thong,cong_thoat_nuoc,ong_dan_nuoc,tru_chua_chay,tram_sac
GEMINI_API_KEY=

# Frontend
FRONTEND_PORT=5174
VITE_BASE_API_URL=/api/v1
VITE_LEADERBOARD_URL=https://contribapi.openinfra.space/api
# VietMap API key (used by backend tile proxy)
# VITE_VIETMAP_API_KEY is kept in .env for backward compat, mapped to VIETMAP_API_KEY for backend

# Admin Auth
ADMIN_JWT_SECRET=change-me
ADMIN_JWT_ALGORITHM=HS256
ADMIN_JWT_EXPIRE_MINUTES=1440
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=change-me

# Mongo Express
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=change-me

# MQTT (IoT Producer)
MQTT_USER=openinfra
MQTT_PASS=change-me

# Contribution DB (ETL sync)
CONTRIB_MONGO_URL=mongodb://user:pass@host.docker.internal:27018/openinfra_gis?authSource=openinfra_gis

# MCP Server
MCP_PORT=8003

# MongoDB Port
MONGO_PORT=27017

# ============================================================
# Auto IP Detection (Router → Cloudflare DDNS)
# ============================================================
AUTOIP_HOST=192.168.1.1
AUTOIP_PORT=1443
AUTOIP_USERNAME=admin
AUTOIP_PASSWORD=change-me

# Cloudflare DNS (also used by celery worker for auto-refresh)
CF_API_TOKEN=your_cloudflare_api_token
CF_ZONE_ID=your_zone_id
CF_DOMAIN=openinfra.space
CF_RECORDS=@ api mcp
CF_PROXIED=true
CF_EMAIL=admin@openinfra.space
