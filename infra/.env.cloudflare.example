# Cloudflare DNS Config
# Get API token: https://dash.cloudflare.com/profile/api-tokens
# Create token with Zone:DNS:Edit permission for openinfra.space

CF_API_TOKEN=your_cloudflare_api_token_here
CF_ZONE_ID=your_zone_id_here
CF_DOMAIN=openinfra.space
CF_RECORDS="@ api mcp"
CF_PROXIED=true
CF_TTL=1
CF_EMAIL=admin@openinfra.space
