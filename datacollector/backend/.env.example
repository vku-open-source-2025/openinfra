# MongoDB Connection (with authentication)
# Format: mongodb://username:password@host:port/database?authSource=database
MONGO_URL=mongodb://mongodb_admin:CHANGE_PASSWORD@mongo:27017/openinfra_gis?authSource=openinfra_gis

# Admin Credentials - Used for JWT authentication (NOT Basic Auth!)
# Generate with: python3 generate_credentials.py
# Password requirements: 20+ chars, mixed case, numbers, symbols
ADMIN_USERNAME=admin_change_this
ADMIN_PASSWORD=Change-This-To-Strong-Password-20chars!

# JWT Configuration - SECURITY: Never use default values!
JWT_SECRET_KEY=your-secret-key-please-change-this-to-a-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Production Environment (optional)
# ENVIRONMENT=production
